FROM python:3.10-slim

LABEL maintainer="openmlops-challenge"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install MLflow
RUN pip install --no-cache-dir mlflow>=2.10 boto3>=1.28

# Create artefact directory
RUN mkdir -p /mlflow-artifacts

EXPOSE 5000

# MLflow server: SQLite backend + local artefact store
# Override ARTIFACT_ROOT via env var when using S3
CMD ["mlflow", "server", \
     "--host", "0.0.0.0", \
     "--port", "5000", \
     "--backend-store-uri", "sqlite:///mlflow.db", \
     "--default-artifact-root", "/mlflow-artifacts"]
