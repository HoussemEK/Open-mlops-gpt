# ─────────────────────────────────────────────────────────────
# OpenMLOps Challenge — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git!
# ─────────────────────────────────────────────────────────────

# MLflow tracking server (used by training & monitoring containers)
MLFLOW_TRACKING_URI=http://mlflow-server:5000

# ZenML server URL
ZENML_SERVER_URL=http://zenml-server:8080
ZENML_DEFAULT_USER_NAME=admin
ZENML_DEFAULT_USER_PASSWORD=admin

# AWS credentials for DVC S3 remote
# R-INF-4: credentials injected via env vars, never hardcoded
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=aws-session-token
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for DVC remote
S3_BUCKET_NAME=your-dvc-bucket-name
DVC_REMOTE_URL=s3://your-dvc-bucket-name/dvc-store

# Optional: set to "true" to use drifted data in monitoring pipeline
USE_DRIFTED_DATA=false
